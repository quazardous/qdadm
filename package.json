{
  "name": "qdadm-monorepo",
  "private": true,
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "dev": "npm run dev -w packages/demo",
    "build": "npm run build -w packages/demo",
    "preview": "npm run preview -w packages/demo",
    "test": "npm test --workspaces --if-present",
    "type-check": "npm run type-check --workspaces --if-present",
    "smoke:consumer": "bash tools/consumer-smoke/run.sh",
    "changeset": "changeset",
    "release:status": "changeset status",
    "release:version": "changeset version && npm install --package-lock-only",
    "release:publish": "npm test --workspaces --if-present && changeset publish"
  },
  "version": "0.1.1",
  "devDependencies": {
    "@changesets/cli": "^2.31.0"
  }
}
